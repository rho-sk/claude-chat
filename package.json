{
  "name": "claude-chat",
  "version": "0.1.0",
  "description": "Chat with Claude Code inside Obsidian via ACP",
  "main": "src/main.ts",
  "private": true,
  "scripts": {
    "build": "node build/esbuild.mjs",
    "dev": "node build/esbuild.mjs --watch",
    "install-plugin": "node build/esbuild.mjs && node build/install.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.3",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "obsidian": "latest",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.1"
  }
}
